{
  "info": {
    "name": "Investment Helper User Service",
    "_postman_id": "4b3f2d89-8f2f-4c7b-9b0e-ih-user-service",
    "description": "Postman collection for testing User Service endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1/users"
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "createdEmail",
      "value": "john.doe@example.com"
    }
  ],
  "item": [
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"{{createdEmail}}\",\n  \"password\": \"password123\",\n  \"dateOfBirth\": \"2000-01-15\",\n  \"role\": \"ROLE_USER\"\n}"
        },
        "url": "{{baseUrl}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "var jsonData = pm.response.json();",
              "if (jsonData && jsonData.id) {",
              "    pm.collectionVariables.set('userId', jsonData.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get All Users",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get User By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/{{userId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Patch User By Id",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Johnny\",\n  \"lastName\": \"Updated\",\n  \"email\": \"john.updated@example.com\",\n  \"password\": \"newpassword123\",\n  \"dateOfBirth\": \"2000-01-15\",\n  \"role\": \"ROLE_ADMIN\"\n}"
        },
        "url": "{{baseUrl}}/{{userId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete User By Id",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/{{userId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 204 No Content', function () {",
              "    pm.response.to.have.status(204);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create User - Duplicate Email (409)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"{{createdEmail}}\",\n  \"password\": \"password123\",\n  \"dateOfBirth\": \"2000-01-15\",\n  \"role\": \"ROLE_USER\"\n}"
        },
        "url": "{{baseUrl}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 409 Conflict', function () {",
              "    pm.response.to.have.status(409);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create User - Validation Error (400)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"\",\n  \"lastName\": \"D\",\n  \"email\": \"bad\",\n  \"password\": \"12\",\n  \"dateOfBirth\": \"3000-01-01\",\n  \"role\": \"INVALID_ROLE\"\n}"
        },
        "url": "{{baseUrl}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 400 Bad Request', function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}